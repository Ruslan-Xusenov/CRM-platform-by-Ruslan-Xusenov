# ============================================
# Omnichannel CRM & WebRTC PBX Platform
# Environment Configuration
# ============================================

# --- Application ---
APP_ENV=development
APP_PORT=8080
APP_SECRET=change-me-to-a-strong-random-secret-key
APP_DOMAIN=localhost
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crm_platform
POSTGRES_USER=crm_admin
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=crm_broker
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/

# --- MinIO (S3-Compatible Object Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=crm_storage_admin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET_RECORDINGS=call-recordings
MINIO_BUCKET_FILES=crm-files
MINIO_USE_SSL=false

# --- Asterisk PBX ---
ASTERISK_ARI_URL=http://asterisk:8088/ari
ASTERISK_ARI_USER=crm_ari
ASTERISK_ARI_PASSWORD=change-me-ari-password
ASTERISK_AMI_HOST=asterisk
ASTERISK_AMI_PORT=5038
ASTERISK_WSS_PORT=8089

# --- JWT ---
JWT_ACCESS_SECRET=change-me-jwt-access-secret-key-min-32-chars
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
